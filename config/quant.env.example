# QuantLab local configuration.
# Copy this file to config/quant.env and fill in private values.
# Process environment variables override values from this file.

# Service
QUANT_BACKEND_HOST=0.0.0.0
QUANT_BACKEND_PORT=8001
QUANT_FRONTEND_HOST=0.0.0.0
QUANT_FRONTEND_PORT=5174
QUANT_CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
QUANT_RELOAD=0
QUANT_MEMORY_HIGH=9G
QUANT_MEMORY_MAX=10G

# TuShare
TUSHARE_TOKEN=
TUSHARE_RPM=180
TUSHARE_WORKERS=4
TUSHARE_RETRIES=2
TUSHARE_FETCH_ADJ_FACTOR=0

# TongDaXin
TDX_HOST=
TDX_PORT=7709
TDX_CONNECT_TIMEOUT=2
TDX_MAX_HOST_ATTEMPTS=4
TDX_HOST_COOLDOWN=120
TDX_WORKERS=4
TDX_REQUEST_RETRIES=2
TDX_EMPTY_RESPONSE_THRESHOLD=3
TDX_PROBE_TIMEOUT=0.8
TDX_PROBE_WORKERS=24
TDX_ACTIVE_HOSTS=8
TDX_HOST_CACHE_SECONDS=21600

# Other market-data sources and resource limits
AKSHARE_WORKERS=4
BAOSTOCK_WORKERS=1
DATA_MEMORY_BUDGET_GB=10
DATA_ESTIMATED_WORKER_MB=256
DATA_REQUEST_DELAY=0.08
DATA_MAX_CONSECUTIVE_ERRORS=12

# AI Agent
AGENT_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
ANTHROPIC_API_KEY=
AGENT_MODEL=deepseek-v4-flash
AGENT_MAX_TOKENS=4096

# Futu OpenD
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
